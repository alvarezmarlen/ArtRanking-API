{
  "info": {
    "name": "ArtRanking API",
    "description": "API para concursos de arte con ranking por votos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Concursos",
      "item": [
        {
          "name": "Crear Concurso",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{base_url}}/concursos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Concurso de Pintura 2025\",\n  \"descripcion\": \"Arte abstracto y moderno\",\n  \"fecha_inicio\": \"2025-01-01T00:00:00\",\n  \"fecha_fin\": \"2025-12-31T23:59:59\",\n  \"categorias\": [\n    {\"nombre\": \"Óleo\", \"descripcion\": \"Pintura al óleo\"},\n    {\"nombre\": \"Acuarela\", \"descripcion\": \"Técnica acuarela\"}\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar Concursos",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/concursos?activos=true"
          }
        },
        {
          "name": "Detalle Concurso",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/concursos/{{concurso_id}}"
          }
        },
        {
          "name": "Agregar Categoría",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{base_url}}/concursos/{{concurso_id}}/categorias",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Digital\",\n  \"descripcion\": \"Arte digital\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Envíos",
      "item": [
        {
          "name": "Crear Envío",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{base_url}}/envios",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Mi Obra Maestra\",\n  \"descripcion\": \"Una pintura inspirada\",\n  \"imagen_url\": \"https://example.com/imagen.jpg\",\n  \"concurso_id\": \"{{concurso_id}}\",\n  \"categoria_id\": \"{{categoria_id}}\",\n  \"etiquetas\": [\"naturaleza\", \"paisaje\"]\n}"
            }
          }
        },
        {
          "name": "Listar Envíos",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/envios?concurso={{concurso_id}}"
          }
        },
        {
          "name": "Votar Envío",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/envios/{{envio_id}}/votar"
          }
        },
        {
          "name": "Ranking",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/envios/concurso/{{concurso_id}}/ranking?limite=10"
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://localhost:5000"},
    {"key": "token", "value": ""},
    {"key": "concurso_id", "value": ""},
    {"key": "categoria_id", "value": ""},
    {"key": "envio_id", "value": ""}
  ]
}
